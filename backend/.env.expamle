  # =========================
  # 基础运行配置
  # =========================
  DEBUG=True
  HOST=127.0.0.1
  PORT=8000
  LOG_LEVEL=INFO
  LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

  # =========================
  # 安全与认证配置
  # =========================
  SECRET_KEY=replace-with-your-secret-key
  JWT_SECRET_KEY=replace-with-your-jwt-secret-key
  JWT_ALGORITHM=HS256
  JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
  JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

  # =========================
  # 数据库配置
  # 默认使用 SQLite
  # =========================
  DATABASE_URL=sqlite+aiosqlite:///./data/app.db

  # =========================
  # OpenAI接口兼容
  # 用于反诈助手、训练教练等能力
  # =========================
  OPENAI_API_KEY=
  OPENAI_BASE_URL=
  OPENAI_MODEL=
  OPENAI_TEMPERATURE=0.2

  # =========================
  # 智谱语音识别配置
  # 用于语音风险分析
  # =========================
  ZHIPU_AUDIO_API_KEY=
  ZHIPU_AUDIO_BASE_URL=https://open.bigmodel.cn/api/paas/v4
  ZHIPU_AUDIO_MODEL=glm-asr-2512

  # =========================
  # 风险核验外部检索配置
  # 二选一即可：
  # 1. SERPAPI_API_KEY
  # 2. SEARCH_API_KEY + SEARCH_ENGINE_ID
  # =========================
  SERPAPI_API_KEY=
  SEARCH_API_KEY=
  SEARCH_ENGINE_ID=

  # =========================
  # 视觉模型接口配置
  # 用于截图/图像风险增强分析
  # =========================
  VISION_API_KEY=
  VISION_BASE_URL=
  VISION_MODEL=
  VISION_TEMPERATURE=0.1

  # =========================
  # 本地模型与向量检索配置
  # =========================
  EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
  EMBEDDING_DEVICE=cuda
  LOCAL_MODEL_NAME=gpt-neo-2.7B
  LOCAL_MODEL_REF_PATH=text_aigc/local_infer_ref
  LOCAL_MODEL_CACHE_DIR=../cache
  SIMILARITY_TOP_K=3
  CHUNK_SIZE=512

  # =========================
  # 服务运行配置
  # =========================
  MAX_WORKERS=4
  REQUEST_TIMEOUT=30
  USE_OPENAI_API=True
  MAX_CONTENT_LENGTH=16777216

  # =========================
  # 跨域配置
  # =========================
  CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]